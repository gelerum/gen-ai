nextflow.enable.dsl = 2

params {
    outdir = "${launchDir}/data/raw/pdb_mmCIF"
    disprot_outdir = "${launchDir}/data/raw/disprot"
    disprot_url = "https://disprot.org/api/v2/download?format=tsv&release=current&term_ontology=IDPO&term_ontology=GO"
    disprot_filename = "disprot_current_idpo_go.tsv"
    uniprot_outdir = "${launchDir}/data/raw/uniprot"
    dataset_outdir = "${launchDir}/data/processed/disprot"
    dataset_filename = "disprot_sequence_disorder.parquet"
    uniprot_base_url = "https://rest.uniprot.org/uniprotkb"
    disprot_script = "${launchDir}/preprocessing/build_disprot_dataset.py"
    mobidb_url = "https://protein.bio.unipd.it/shared/mobidb/mobidb_gold_2022_07.mjson.gz"
    mobidb_outdir = "${launchDir}/data/raw/mobidb"
    mobidb_filename = "mobidb_gold_2022_07.mjson.gz"
    mobidb_dataset_outdir = "${launchDir}/data/processed/mobidb"
    mobidb_dataset_filename = "mobidb_gold_2022_07.parquet"
    mobidb_script = "${launchDir}/preprocessing/build_mobidb_gold_parquet.py"
    mobidb_mode = "dataset"
    mobidb_disorder_key = "curated-disorder-merge"
    mobidb_disorder_variants = "curated=curated-disorder-merge;homology=homology-disorder-merge;prediction_priority=prediction-disorder-priority;prediction_mobidb_lite=prediction-disorder-mobidb_lite;all_priority=curated-disorder-merge,homology-disorder-merge,prediction-disorder-priority"
    mobidb_primary_disorder_variant = "curated"
    mobidb_curl_timeout = 0
    ids = null
    limit = 0
    chunk_size = 200
    max_forks = 6
    retries = 3
    curl_timeout = 120
    pdb_index_url = "https://files.wwpdb.org/pub/pdb/derived_data/index/entries.idx"
    mmcif_base_url = "https://files.wwpdb.org/pub/pdb/data/structures/divided/mmCIF"

    // Stage 2: RCSB PDB feature extraction
    raw = "${launchDir}/data/raw/pdb_mmCIF"
    processed_outdir = "${launchDir}/data/processed"
    extract_script = "${launchDir}/preprocessing/extract_pdb_features.py"

    // Stage 3: merge DisProt + MobiDB + RCSB PDB into one unified dataset
    pdb_dataset_filename = "pdb_protein_features.parquet"
    merged_filename = "merged_protein_dataset.parquet"
    merge_script = "${launchDir}/preprocessing/merge_datasets.py"

    // Stage 4: clean the merged dataset
    clean_filename = "merged_protein_dataset_clean.parquet"
    clean_script = "${launchDir}/preprocessing/clean_merged_dataset.py"

    // Stage 5: attach per-sequence ESM2 embeddings for one organism
    embed_script = "${launchDir}/preprocessing/embed_esm2.py"
    embed_filename = "merged_protein_dataset_human_esm2.parquet"
    embed_taxonomy_id = "9606"
    embed_model = "facebook/esm2_t6_8M_UR50D"
    embed_batch_size = 32
    // Residues per attention window; long proteins are split into windows and
    // mean-pooled across all of them, so nothing is truncated.
    embed_window = 1022
}

process {
    executor = "local"
    cpus = 1
    maxRetries = 2
    errorStrategy = "retry"
}
