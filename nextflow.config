nextflow.enable.dsl = 2

params {
    outdir = "${launchDir}/data/raw/rcsb"
    disprot_outdir = "${launchDir}/data/raw/disprot"
    disprot_url = "https://disprot.org/api/v2/download?format=tsv&release=current&term_ontology=IDPO&term_ontology=GO"
    disprot_filename = "disprot_current_idpo_go.tsv"
    uniprot_outdir = "${launchDir}/data/raw/uniprot"
    dataset_outdir = "${launchDir}/data/processed/disprot"
    dataset_filename = "disprot_sequence_disorder.parquet"
    uniprot_base_url = "https://rest.uniprot.org/uniprotkb"
    ids = null
    limit = 0
    chunk_size = 200
    max_forks = 6
    retries = 3
    curl_timeout = 120
    pdb_index_url = "https://files.wwpdb.org/pub/pdb/derived_data/index/entries.idx"
    mmcif_base_url = "https://files.wwpdb.org/pub/pdb/data/structures/divided/mmCIF"
}

process {
    executor = "local"
    cpus = 1
    maxRetries = 2
    errorStrategy = "retry"
}
